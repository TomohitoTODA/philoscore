{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "eqeqeq": ["warn", "always"],
    "no-var": "error",
    "prefer-const": "warn"
  },
  "globals": {
    "PDFLib": "readonly",
    "pdfjsLib": "readonly",
    "google": "readonly"
  }
}
